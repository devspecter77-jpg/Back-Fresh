# @BotFather dan olingan bot tokeni (hech qachon kodga yozmang, faqat shu faylda saqlang)
BOT_TOKEN=your_bot_token_here

# Admin Telegram chat ID (limit berish / bloklash huquqiga ega yagona foydalanuvchi)
ADMIN_ID=123456789

# To'lovdan keyin foydalanuvchilar murojaat qiladigan admin username
ADMIN_CONTACT=@your_admin_username

# Ro'yxatdan o'tgan yangi foydalanuvchiga beriladigan bepul urinishlar soni
FREE_ATTEMPTS=5

# To'lov qabul qilinadigan karta raqami (foydalanuvchilarga shu ko'rsatiladi)
PAYMENT_CARD=0000 0000 0000 0000

# Narx ma'lumoti (faqat matn sifatida ko'rsatiladi, hisob-kitob admin tomonidan qo'lda /addcredit orqali qilinadi)
PRICE_SOM=10
PRICE_ATTEMPTS=60

# rembg modeli: u2net (standart), isnet-general-use (yanada aniqroq, lekin ~170MB, sekin
# internetda yuklab bo'lmasligi mumkin) yoki u2netp (eng yengil/tez, kichikroq server uchun)
REMBG_MODEL=u2net

# Ixtiyoriy: Railway kabi platformalarda doimiy Volume ulangan bo'lsa, shu Volume yo'lini
# ko'rsating (masalan /data) — baza, saqlangan fonlar va AI-model shu yerda saqlanadi va
# konteyner qayta ishga tushganda yo'qolmaydi. Lokalda bo'sh qoldiring.
# APP_DATA_DIR=/data
